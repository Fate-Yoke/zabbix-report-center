# ============================================
# Zabbix Report Center 环境变量配置
# ============================================

# MySQL 数据库密码（Docker 部署时使用）
MYSQL_ROOT_PASSWORD=zabbix123456

# JWT 密钥（用于 Token 签名，生产环境请修改）
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-please-change-in-production

# 加密密钥（用于敏感信息加密，如 Zabbix 密码、邮件密码等）
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠️ 警告：更改此密钥后，已加密的数据将无法解密！
ENCRYPTION_KEY=your-encryption-key-here-please-change-in-production

# 调试模式（生产环境请设置为 false）
DEBUG=false

# ============================================
# 以下配置仅在非 Docker 部署时需要
# ============================================

# 数据库配置（本地部署使用 MySQL）
# DATABASE_URL=mysql+pymysql://root:password@localhost/zabbix_report_center

# 数据库配置（本地部署使用 SQLite）
# DATABASE_URL=sqlite:///zabbix_web.db
